---
import BaseLayout from './BaseLayout.astro';
import CulturalDivider from '@/components/ui/CulturalDivider.astro';

interface Props {
  title: string;
  date: string;
  author: string;
  slug: string;
  image?: string;
  imageCaption?: string;
}

const { title, date, author, slug, image, imageCaption } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} — BMGR Blog`}>
  <article class="py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-6">
      <a href="/blog/" class="inline-flex items-center gap-1 text-xs text-gold font-semibold uppercase tracking-wider hover:underline mb-8">&larr; All posts</a>

      <header class="mb-10">
        <div class="flex items-center gap-3 text-xs text-earth-faint mb-3">
          <time datetime={date}>{formatted}</time>
          <span class="w-1 h-1 rounded-full bg-earth-faint"></span>
          <span>{author}</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-bold">{title}</h1>
      </header>

      {image && (
        <div class="rounded-xl overflow-hidden mb-10">
          <img src={image} alt={imageCaption || title} class="w-full" loading="lazy" />
          {imageCaption && <p class="text-xs text-earth-faint mt-2 italic">{imageCaption}</p>}
        </div>
      )}

      <CulturalDivider variant="geometric" class="mb-10" />

      <div class="space-y-5 text-earth-muted leading-relaxed">
        <slot />
      </div>

      <CulturalDivider variant="wave" class="my-10" />

      <!-- Newsletter -->
      <div class="bg-earth-surface border border-earth-faint/10 rounded-xl p-5 mb-12">
        <h3 class="font-display text-sm font-semibold mb-1">Get updates from BMGR</h3>
        <p class="text-xs text-earth-muted mb-3">Event reminders and news delivered to your inbox.</p>
        <form id="post-newsletter" class="flex gap-2">
          <input type="email" required placeholder="your@email.com" class="flex-1 px-3 py-2 bg-earth-bg border border-earth-faint/20 rounded-lg text-sm text-earth-warm focus:border-gold focus:ring-1 focus:ring-gold transition" />
          <button type="submit" class="px-4 py-2 bg-crimson text-white text-xs font-bold uppercase tracking-wider rounded-lg hover:bg-crimson-hover transition cursor-pointer">Subscribe</button>
        </form>
      </div>

      <!-- Comments -->
      <section>
        <h3 class="font-display text-xl font-bold mb-6">Comments</h3>
        <form id="comment-form" class="mb-8 bg-earth-surface border border-earth-faint/10 rounded-xl p-5">
          <div class="grid sm:grid-cols-2 gap-3 mb-3">
            <div><label for="c-name" class="block text-xs font-semibold text-earth-faint uppercase tracking-wider mb-1">Name</label><input type="text" id="c-name" required class="w-full px-3 py-2 bg-earth-bg border border-earth-faint/20 rounded-lg text-sm text-earth-warm focus:border-gold focus:ring-1 focus:ring-gold transition" /></div>
            <div><label for="c-email" class="block text-xs font-semibold text-earth-faint uppercase tracking-wider mb-1">Email (not published)</label><input type="email" id="c-email" required class="w-full px-3 py-2 bg-earth-bg border border-earth-faint/20 rounded-lg text-sm text-earth-warm focus:border-gold focus:ring-1 focus:ring-gold transition" /></div>
          </div>
          <div class="mb-3"><label for="c-text" class="block text-xs font-semibold text-earth-faint uppercase tracking-wider mb-1">Comment</label><textarea id="c-text" rows="3" required class="w-full px-3 py-2 bg-earth-bg border border-earth-faint/20 rounded-lg text-sm text-earth-warm focus:border-gold focus:ring-1 focus:ring-gold transition resize-none"></textarea></div>
          <button type="submit" class="px-5 py-2 bg-gold text-earth-bg text-xs font-bold uppercase tracking-wider rounded-lg hover:bg-gold-hover transition cursor-pointer">Post Comment</button>
        </form>
        <div id="comments-list" class="space-y-4"></div>
        <p id="no-comments" class="text-sm text-earth-faint italic">No comments yet. Be the first to share your thoughts!</p>
      </section>
    </div>
  </article>
</BaseLayout>

<script define:vars={{ slug }}>
  function initBlogPost() {
    const KEY = 'bmgr-comments-' + slug;
    const form = document.getElementById('comment-form');
    const list = document.getElementById('comments-list');
    const none = document.getElementById('no-comments');
    function load() { try { return JSON.parse(localStorage.getItem(KEY)||'[]'); } catch { return []; } }
    function render() { const c = load(); if (!list) return; if (!c.length) { list.innerHTML=''; none?.classList.remove('hidden'); return; } none?.classList.add('hidden'); list.innerHTML = c.map((x)=>`<div class="p-4 bg-earth-surface border border-earth-faint/10 rounded-xl"><div class="flex items-center gap-2 mb-2"><div class="w-7 h-7 rounded-full bg-gold/15 flex items-center justify-center text-xs font-bold text-gold">${x.name[0].toUpperCase()}</div><span class="text-sm font-semibold text-earth-warm">${x.name}</span><span class="text-[10px] text-earth-faint ml-auto">${x.date}</span></div><p class="text-sm text-earth-muted">${x.text}</p></div>`).join(''); }
    form?.addEventListener('submit',(e)=>{e.preventDefault();const n=document.getElementById('c-name').value.trim();const t=document.getElementById('c-text').value.trim();const c=load();c.push({name:n,text:t,date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})});localStorage.setItem(KEY,JSON.stringify(c));form.reset();render();});
    render();
    const nl = document.getElementById('post-newsletter');
    nl?.addEventListener('submit',(e)=>{e.preventDefault();const b=nl.querySelector('button');const i=nl.querySelector('input');if(b){const o=b.textContent;b.textContent='Subscribed!';b.disabled=true;i.value='';setTimeout(()=>{b.textContent=o;b.disabled=false;},3000);}});
  }
  initBlogPost(); document.addEventListener('astro:after-swap', initBlogPost);
</script>

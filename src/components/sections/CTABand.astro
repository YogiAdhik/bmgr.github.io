---
import Button from '@/components/ui/Button.astro';
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-crimson/10 via-earth-bg to-gold/10"></div>

  <!-- Decorative circles -->
  <div class="absolute top-0 right-0 w-64 h-64 rounded-full bg-crimson/5 -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full bg-gold/5 translate-y-1/3 -translate-x-1/4"></div>

  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <h2
      class="font-display text-3xl md:text-4xl lg:text-5xl font-bold mb-4 reveal"
    >
      Be Part of the <span class="italic text-gold">Music</span>
    </h2>
    <p class="text-lg text-earth-muted mb-8 reveal reveal-delay-1">
      Whether you sing, play, or simply love Nepali music — there's a place for you at BMGR.
      Join us in preserving our cultural heritage through the power of music.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal reveal-delay-2">
      <Button href="/contact/" variant="gold" size="lg">Get Involved</Button>
      <Button href="/members/" variant="secondary" size="lg">Meet the Team</Button>
    </div>
  </div>
</section>

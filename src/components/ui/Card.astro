---
interface Props {
  class?: string;
  hover?: boolean;
  culturalBorder?: boolean;
}

const { class: className, hover = true, culturalBorder = false } = Astro.props;
---

<div
  class:list={[
    'rounded-xl bg-earth-surface border border-earth-faint/10 p-6 transition-all duration-300',
    hover && 'hover:-translate-y-2 hover:shadow-xl hover:shadow-crimson/5 hover:border-gold/20',
    culturalBorder && 'cultural-border-top',
    className,
  ]}
>
  <slot />
</div>

---
import type { Event } from '@/config/site.config';

interface Props {
  event: Event;
}

const { event } = Astro.props;

const statusColors = {
  upcoming: 'bg-crimson/20 text-crimson',
  recurring: 'bg-gold/20 text-gold',
  planned: 'bg-earth-faint/20 text-earth-muted',
};
---

<div class="event-card group flex gap-4 bg-earth-surface border border-earth-faint/10 rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-crimson/5 hover:border-gold/20">
  <!-- Left accent -->
  <div class="w-1 rounded-full bg-gradient-to-b from-crimson to-gold shrink-0"></div>

  <!-- Content -->
  <div class="flex-1">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-display text-lg font-semibold group-hover:text-gold transition-colors">
        {event.title}
      </h3>
      <span class:list={['text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0', statusColors[event.status]]}>
        {event.status}
      </span>
    </div>

    <p class="text-sm text-gold font-medium mb-2">
      {event.date}
      {event.time && ` · ${event.time}`}
    </p>

    <p class="text-sm text-earth-muted leading-relaxed">
      {event.description}
    </p>
  </div>
</div>

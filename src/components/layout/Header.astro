---
import { siteConfig } from '@/config/site.config';
import Navigation from './Navigation.astro';

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 h-16 md:h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="BMGR Home">
      <img
        src={siteConfig.logo.src}
        alt={siteConfig.logo.alt}
        class="w-10 h-10 md:w-12 md:h-12 rounded-full transition-transform group-hover:scale-105"
        width="48"
        height="48"
      />
      <span class="font-display text-xl md:text-2xl font-bold text-earth-warm">
        BMGR
      </span>
    </a>

    <!-- Desktop Nav -->
    <Navigation currentPath={currentPath} />

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="md:hidden relative w-10 h-10 flex items-center justify-center"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="hamburger-line top-[12px]"></span>
      <span class="hamburger-line top-[19px]"></span>
      <span class="hamburger-line top-[26px]"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-16 bg-earth-bg/98 backdrop-blur-xl -translate-x-full transition-transform duration-300 md:hidden z-40"
  >
    <nav class="flex flex-col items-center justify-center h-full gap-8 -mt-16">
      {siteConfig.nav.map((item, i) => (
        <a
          href={item.href}
          class:list={[
            'mobile-nav-link text-2xl font-display font-semibold transition-colors',
            currentPath === item.href ? 'text-gold' : 'text-earth-warm hover:text-gold',
          ]}
          style={`--delay: ${i * 0.08}s`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-20"></div>

<style>
  .hamburger-line {
    position: absolute;
    width: 22px;
    height: 2px;
    background-color: var(--color-earth-warm);
    transition: all 0.3s ease;
    left: 50%;
    transform: translateX(-50%);
  }

  #menu-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    top: 19px;
    transform: translateX(-50%) rotate(45deg);
  }
  #menu-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #menu-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    top: 19px;
    transform: translateX(-50%) rotate(-45deg);
  }

  #site-header.scrolled {
    background-color: rgba(14, 10, 6, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(212, 148, 26, 0.1);
  }

  .mobile-nav-link {
    opacity: 0;
    transform: translateX(-20px);
  }

  #mobile-menu:not(.-translate-x-full) .mobile-nav-link {
    animation: nav-slide-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) var(--delay) forwards;
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    // Scroll detection
    const onScroll = () => {
      header?.classList.toggle('scrolled', window.scrollY > 20);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu toggle
    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu?.classList.toggle('-translate-x-full');
      document.body.style.overflow = expanded ? '' : 'hidden';
    });

    // Close menu on link click
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle?.setAttribute('aria-expanded', 'false');
        menu.classList.add('-translate-x-full');
        document.body.style.overflow = '';
      });
    });
  }
  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
